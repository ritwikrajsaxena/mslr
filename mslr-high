# PHASE 4: TEACHER ENSEMBLE
# ============================================================
class TeacherEnsemble:
    def __init__(self, models_and_types):
        """models_and_types: list of (model, model_type, val_acc)"""
        self.models = [(m.cpu(), mt) for m, mt, _ in models_and_types]
        self.weights = [acc for _, _, acc in models_and_types]
        total_w = sum(self.weights)
        self.weights = [w / total_w for w in self.weights]
    
    @torch.no_grad()
    def get_soft_labels(self, loader, device, config, temperature=4.0):
        all_ids, all_soft = [], []
        
        for batch in tqdm(loader, desc="Generating soft labels"):
            x = batch[0].to(device)
            sample_ids = batch[-1]
            
            weighted_logits = None
            for (model, mt), weight in zip(self.models, self.weights):
                model.to(device).eval()
                with autocast(enabled=config['use_amp']):
                    logits = model(x)
                if weighted_logits is None:
                    weighted_logits = weight * logits
                else:
                    weighted_logits += weight * logits
                model.cpu()
                clear_memory()
            
            soft = F.softmax(weighted_logits / temperature, dim=1)
            all_soft.append(soft.cpu().numpy())
            all_ids.extend(sample_ids.numpy() if torch.is_tensor(sample_ids) else sample_ids)
        
        return all_ids, np.concatenate(all_soft, axis=0)
    
    @torch.no_grad()
    def predict(self, loader, device, config, use_tta=True):
        all_ids, all_logits = [], []
        
        for batch in tqdm(loader, desc="Ensemble predicting"):
            x = batch[0].to(device)
            sample_ids = batch[-1]
            
            weighted_logits = None
            for (model, mt), weight in zip(self.models, self.weights):
                model.to(device).eval()
                with autocast(enabled=config['use_amp']):
                    logits = model(x)
                    if use_tta:
                        logits += model(x.flip(-1))
                        logits += model(x.flip(-2))
                        logits /= 3
                if weighted_logits is None:
                    weighted_logits = weight * logits
                else:
                    weighted_logits += weight * logits
                model.cpu()
                clear_memory()
            
            all_logits.append(weighted_logits.cpu())
            all_ids.extend(sample_ids.numpy() if torch.is_tensor(sample_ids) else sample_ids)
        
        all_logits = torch.cat(all_logits, dim=0)
        return all_ids, all_logits.argmax(dim=1).numpy(), all_logits


