class EarlyStopping:
    def __init__(self, patience=10, mode='max'):
        self.patience = patience
        self.mode = mode
        self.counter = 0
        self.best_score = None
        self.best_model_state = None
    
    def __call__(self, score, model):
        better = (self.best_score is None or 
                  (score > self.best_score if self.mode == 'max' else score < self.best_score))
        if better:
            self.best_score = score
            self.counter = 0
            self.best_model_state = copy.deepcopy(model.state_dict())
            return False
        self.counter += 1
        return self.counter >= self.patience
    
    def load_best_model(self, model):
        if self.best_model_state:
            model.load_state_dict(self.best_model_state)


def mixup_data(x, y, alpha=0.3, device='cuda'):
    lam = np.random.beta(alpha, alpha) if alpha > 0 else 1
    index = torch.randperm(x.size(0), device=device)
    return lam * x + (1 - lam) * x[index], y, y[index], lam


def cutmix_data(x, y, alpha=1.0, device='cuda'):
    lam = np.random.beta(alpha, alpha)
    B, C, H, W = x.shape
    index = torch.randperm(B, device=device)
    
    cut_ratio = np.sqrt(1 - lam)
    cut_h, cut_w = int(H * cut_ratio), int(W * cut_ratio)
    cy, cx = np.random.randint(H), np.random.randint(W)
    y1, y2 = np.clip(cy - cut_h//2, 0, H), np.clip(cy + cut_h//2, 0, H)
    x1, x2 = np.clip(cx - cut_w//2, 0, W), np.clip(cx + cut_w//2, 0, W)
    
    x_clone = x.clone()
    x_clone[:, :, y1:y2, x1:x2] = x[index, :, y1:y2, x1:x2]
    lam = 1 - (y2 - y1) * (x2 - x1) / (H * W)
    
    return x_clone, y, y[index], lam


def train_one_epoch(model, loader, criterion, optimizer, scheduler, scaler,
                    device, config, is_multistream=False):
    model.train()
    total_loss, correct, total = 0, 0, 0
    
    for batch in loader:
        if is_multistream:
            (x1, x2, x3), y, _ = batch
            x1, x2, x3 = x1.to(device), x2.to(device), x3.to(device)
            y = y.to(device)
            inputs = (x1, x2, x3)
        else:
            x, y = batch[0].to(device), batch[1].to(device)
            
            # Mixup / CutMix
            r = random.random()
            if config.get('cutmix_alpha', 0) > 0 and r < config.get('cutmix_prob', 0.3):
                x, y_a, y_b, lam = cutmix_data(x, y, config['cutmix_alpha'], device)
                use_mix = True
            elif config.get('mixup_alpha', 0) > 0 and r < 0.6:
                x, y_a, y_b, lam = mixup_data(x, y, config['mixup_alpha'], device)
                use_mix = True
            else:
                use_mix = False
            inputs = x
        
        with autocast(enabled=config['use_amp']):
            logits = model(inputs)
            if is_multistream or not use_mix:
                loss = criterion(logits, y)
            else:
                loss = lam * criterion(logits, y_a) + (1 - lam) * criterion(logits, y_b)
        
        optimizer.zero_grad()
        scaler.scale(loss).backward()
        scaler.unscale_(optimizer)
        torch.nn.utils.clip_grad_norm_(model.parameters(), config['gradient_clip'])
        scaler.step(optimizer)
        scaler.update()
        if scheduler: scheduler.step()
        
        total_loss += loss.item() * logits.size(0)
        preds = logits.argmax(dim=1)
        if is_multistream or not use_mix:
            correct += (preds == y).sum().item()
        else:
            correct += (lam * (preds == y_a).float() + (1-lam) * (preds == y_b).float()).sum().item()
        total += logits.size(0)
    
    return total_loss / total, correct / total


@torch.no_grad()
def evaluate(model, loader, criterion, device, config, is_multistream=False):
    model.eval()
    total_loss, correct, total = 0, 0, 0
    
    for batch in loader:
        if is_multistream:
            (x1, x2, x3), y, _ = batch
            x1, x2, x3 = x1.to(device), x2.to(device), x3.to(device)
            y = y.to(device)
            inputs = (x1, x2, x3)
        else:
            x, y = batch[0].to(device), batch[1].to(device)
            inputs = x
        
        with autocast(enabled=config['use_amp']):
            logits = model(inputs)
            loss = criterion(logits, y)
        
        total_loss += loss.item() * logits.size(0)
        correct += (logits.argmax(dim=1) == y).sum().item()
        total += logits.size(0)
    
    return total_loss / total, correct / total


