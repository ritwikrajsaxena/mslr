# ============================================================
class RadarSpecAugment:
    """Enhanced radar-specific augmentations for high-resolution RTMs."""
    
    def __init__(self, p=0.5, strong=False):
        self.p = p
        self.strong = strong
        
        # Parameters scale with resolution
        self.time_mask_param = 16 if strong else 10
        self.range_mask_param = 30 if strong else 20
        self.n_time_masks = 3 if strong else 2
        self.n_range_masks = 3 if strong else 2
        self.time_shift_max = 12 if strong else 8
        self.range_shift_max = 6 if strong else 4
        self.noise_std = 0.12 if strong else 0.08
    
    def time_mask(self, rtm):
        if random.random() > self.p: return rtm
        rtm = rtm.copy()
        T, R = rtm.shape
        for _ in range(self.n_time_masks):
            t = random.randint(1, min(self.time_mask_param, T - 1))
            t0 = random.randint(0, T - t)
            rtm[t0:t0+t, :] = 0
        return rtm
    
    def range_mask(self, rtm):
        if random.random() > self.p: return rtm
        rtm = rtm.copy()
        T, R = rtm.shape
        for _ in range(self.n_range_masks):
            r = random.randint(1, min(self.range_mask_param, R - 1))
            r0 = random.randint(0, R - r)
            rtm[:, r0:r0+r] = 0
        return rtm
    
    def time_shift(self, rtm):
        if random.random() > self.p: return rtm
        return np.roll(rtm, random.randint(-self.time_shift_max, self.time_shift_max), axis=0)
    
    def range_shift(self, rtm):
        if random.random() > self.p: return rtm
        return np.roll(rtm, random.randint(-self.range_shift_max, self.range_shift_max), axis=1)
    
    def add_noise(self, rtm):
        if random.random() > self.p: return rtm
        return rtm + np.random.randn(*rtm.shape).astype(np.float32) * self.noise_std
    
    def scale(self, rtm):
        if random.random() > self.p: return rtm
        return rtm * random.uniform(0.85, 1.15)
    
    def time_warp(self, rtm):
        if random.random() > 0.3: return rtm
        T, R = rtm.shape
        warp = random.uniform(0.85, 1.15)
        new_T = int(T * warp)
        t = torch.tensor(rtm, dtype=torch.float32).unsqueeze(0).unsqueeze(0)
        t = F.interpolate(t, size=(new_T, R), mode='bilinear', align_corners=False)
        t = F.interpolate(t, size=(T, R), mode='bilinear', align_corners=False)
        return t.squeeze().numpy()
    
    def __call__(self, rtm):
        rtm = self.time_shift(rtm)
        rtm = self.range_shift(rtm)
        rtm = self.time_warp(rtm)
        rtm = self.time_mask(rtm)
        rtm = self.range_mask(rtm)
        rtm = self.add_noise(rtm)
        rtm = self.scale(rtm)
        return rtm


