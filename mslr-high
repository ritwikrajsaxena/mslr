# ============================================================
class ProjectionHead(nn.Module):
    """MLP projection head for SupCon."""
    def __init__(self, in_dim, hidden_dim=2048, out_dim=256):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(in_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(inplace=True),
            nn.Linear(hidden_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(inplace=True),
            nn.Linear(hidden_dim, out_dim)
        )
    
    def forward(self, x):
        return F.normalize(self.net(x), dim=1)


class SupConLoss(nn.Module):
    """Supervised Contrastive Loss."""
    
    def __init__(self, temperature=0.07):
        super().__init__()
        self.temperature = temperature
    
    def forward(self, features, labels):
        """
        features: (2*B, dim) - concatenated features from two views
        labels: (2*B,) - concatenated labels
        """
        B = features.shape[0]
        
        # Compute similarity matrix
        sim_matrix = torch.matmul(features, features.T) / self.temperature
        
        # Mask self-similarity
        mask_self = torch.eye(B, device=features.device).bool()
        sim_matrix = sim_matrix.masked_fill(mask_self, -1e9)
        
        # Positive mask: same label, different sample
        labels = labels.unsqueeze(1)
        mask_pos = (labels == labels.T).float()
        mask_pos = mask_pos.masked_fill(mask_self, 0)
        
        # Compute log-softmax
        log_softmax = sim_matrix - torch.logsumexp(sim_matrix, dim=1, keepdim=True)
        
        # Average over positive pairs
        num_pos = mask_pos.sum(dim=1).clamp(min=1)
        loss = -(mask_pos * log_softmax).sum(dim=1) / num_pos
        
        return loss.mean()


class SupConModel(nn.Module):
    """Backbone + Projection Head for SupCon training."""
    
    def __init__(self, backbone, feature_dim, proj_dim=256):
        super().__init__()
        self.backbone = backbone
        self.projector = ProjectionHead(feature_dim, hidden_dim=2048, out_dim=proj_dim)
    
    def forward(self, x):
        features = self.backbone(x)
        projections = self.projector(features)
        return features, projections


def train_supcon(train_samples, config, device, pretrained_encoder=None):
    """Phase 2: Supervised Contrastive Learning."""
    print("\n" + "="*80)
    print("PHASE 2: SUPERVISED CONTRASTIVE LEARNING")
    print("="*80)
    
    # Dataset with two augmented views
    dataset = RadarGestureDataset(
        train_samples, target_frames=config['target_frames'],
        augment=True, mode='supcon'
    )
    loader = DataLoader(
        dataset, batch_size=config['supcon_batch_size'],
        shuffle=True, num_workers=config['num_workers'],
        pin_memory=True, drop_last=True
    )
    
    # Backbone
    backbone = timm.create_model('efficientnet_b4', pretrained=True, num_classes=0, in_chans=3)
    feature_dim = backbone.num_features
    
    supcon_model = SupConModel(backbone, feature_dim, proj_dim=256).to(device)
    
    criterion = SupConLoss(temperature=config['supcon_temperature'])
    optimizer = AdamW(supcon_model.parameters(), lr=config['supcon_lr'], weight_decay=1e-4)
    scheduler = CosineAnnealingWarmRestarts(optimizer, T_0=10, T_mult=2, eta_min=1e-7)
    scaler = GradScaler(enabled=config['use_amp'])
    
    n_params = sum(p.numel() for p in supcon_model.parameters())
    print(f"SupCon model parameters: {n_params:,}")
    
    supcon_losses = []
    
    for epoch in range(config['supcon_epochs']):
        supcon_model.train()
        epoch_loss = 0
        
        pbar = tqdm(loader, desc=f"SupCon Epoch {epoch+1}/{config['supcon_epochs']}")
        for x1, x2, y, _ in pbar:
            x1, x2, y = x1.to(device), x2.to(device), y.to(device)
            
            with autocast(enabled=config['use_amp']):
                # Forward both views
                _, proj1 = supcon_model(x1)
                _, proj2 = supcon_model(x2)
                
                # Concatenate
                projections = torch.cat([proj1, proj2], dim=0)
                labels = torch.cat([y, y], dim=0)
                
                loss = criterion(projections, labels)
            
            optimizer.zero_grad()
            scaler.scale(loss).backward()
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(supcon_model.parameters(), config['gradient_clip'])
            scaler.step(optimizer)
            scaler.update()
            
            epoch_loss += loss.item()
            pbar.set_postfix({'loss': f'{loss.item():.4f}'})
        
        scheduler.step()
        avg_loss = epoch_loss / len(loader)
        supcon_losses.append(avg_loss)
        print(f"  SupCon Epoch {epoch+1}: Loss = {avg_loss:.4f}")
    
    # Save backbone weights
    torch.save({
        'backbone_state_dict': supcon_model.backbone.state_dict(),
        'feature_dim': feature_dim
    }, OUTPUT_DIR / "supcon_backbone.pth")
    
    plt.figure(figsize=(10, 4))
    plt.plot(supcon_losses, linewidth=2)
    plt.xlabel('Epoch')
    plt.ylabel('SupCon Loss')
    plt.title('Supervised Contrastive Learning Loss')
    plt.grid(alpha=0.3)
    plt.savefig(OUTPUT_DIR / "supcon_loss.png", dpi=150, bbox_inches='tight')
    plt.close()
    
    print(f"✓ SupCon pretraining complete. Backbone saved.")
    
    return supcon_model.backbone


