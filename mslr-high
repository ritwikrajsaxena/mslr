class PatchEmbed(nn.Module):
    """Convert RTM to patch embeddings."""
    
    def __init__(self, img_size=(128, 256), patch_size=(8, 16), in_chans=3, embed_dim=768):
        super().__init__()
        self.img_size = img_size
        self.patch_size = patch_size
        self.num_patches = (img_size[0] // patch_size[0]) * (img_size[1] // patch_size[1])
        self.proj = nn.Conv2d(in_chans, embed_dim, kernel_size=patch_size, stride=patch_size)
    
    def forward(self, x):
        # x: (B, C, H, W) -> (B, num_patches, embed_dim)
        x = self.proj(x)
        x = x.flatten(2).transpose(1, 2)
        return x


class MAEEncoder(nn.Module):
    """MAE Encoder - processes only visible (unmasked) patches."""
    
    def __init__(self, img_size=(128, 256), patch_size=(8, 16), in_chans=3,
                 embed_dim=768, depth=12, num_heads=12, mlp_ratio=4.0):
        super().__init__()
        
        self.patch_embed = PatchEmbed(img_size, patch_size, in_chans, embed_dim)
        self.num_patches = self.patch_embed.num_patches
        
        self.cls_token = nn.Parameter(torch.zeros(1, 1, embed_dim))
        self.pos_embed = nn.Parameter(torch.zeros(1, self.num_patches + 1, embed_dim))
        
        self.blocks = nn.ModuleList([
            nn.TransformerEncoderLayer(
                d_model=embed_dim, nhead=num_heads,
                dim_feedforward=int(embed_dim * mlp_ratio),
                dropout=0.0, activation='gelu', batch_first=True,
                norm_first=True
            )
            for _ in range(depth)
        ])
        
        self.norm = nn.LayerNorm(embed_dim)
        self.embed_dim = embed_dim
        
        self._init_weights()
    
    def _init_weights(self):
        nn.init.trunc_normal_(self.pos_embed, std=0.02)
        nn.init.trunc_normal_(self.cls_token, std=0.02)
    
    def forward(self, x, mask_ratio=0.75):
        """
        x: (B, C, H, W)
        Returns: encoded visible patches, mask, ids_restore
        """
        B = x.shape[0]
        
        # Patch embedding
        x = self.patch_embed(x)  # (B, N, D)
        N = x.shape[1]
        
        # Add positional embedding (without cls token)
        x = x + self.pos_embed[:, 1:, :]
        
        # Random masking
        len_keep = int(N * (1 - mask_ratio))
        noise = torch.rand(B, N, device=x.device)
        
        ids_shuffle = torch.argsort(noise, dim=1)
        ids_restore = torch.argsort(ids_shuffle, dim=1)
        
        # Keep only visible patches
        ids_keep = ids_shuffle[:, :len_keep]
        x = torch.gather(x, dim=1, index=ids_keep.unsqueeze(-1).expand(-1, -1, x.shape[-1]))
        
        # Create mask: 0 = keep, 1 = masked
        mask = torch.ones(B, N, device=x.device)
        mask[:, :len_keep] = 0
        mask = torch.gather(mask, dim=1, index=ids_restore)
        
        # Prepend cls token
        cls_tokens = self.cls_token.expand(B, -1, -1) + self.pos_embed[:, :1, :]
        x = torch.cat([cls_tokens, x], dim=1)
        
        # Transformer blocks
        for block in self.blocks:
            x = block(x)
        
        x = self.norm(x)
        
        return x, mask, ids_restore


class MAEDecoder(nn.Module):
    """MAE Decoder - reconstructs masked patches."""
    
    def __init__(self, num_patches, patch_size=(8, 16), in_chans=3,
                 encoder_dim=768, decoder_dim=512, depth=4, num_heads=8):
        super().__init__()
        
        self.decoder_embed = nn.Linear(encoder_dim, decoder_dim)
        self.mask_token = nn.Parameter(torch.zeros(1, 1, decoder_dim))
        self.decoder_pos_embed = nn.Parameter(torch.zeros(1, num_patches + 1, decoder_dim))
        
        self.blocks = nn.ModuleList([
            nn.TransformerEncoderLayer(
                d_model=decoder_dim, nhead=num_heads,
                dim_feedforward=decoder_dim * 4,
                dropout=0.0, activation='gelu', batch_first=True,
                norm_first=True
            )
            for _ in range(depth)
        ])
        
        self.norm = nn.LayerNorm(decoder_dim)
        self.pred = nn.Linear(decoder_dim, patch_size[0] * patch_size[1] * in_chans)
        
        nn.init.trunc_normal_(self.mask_token, std=0.02)
        nn.init.trunc_normal_(self.decoder_pos_embed, std=0.02)
    
    def forward(self, x, ids_restore):
        """
        x: encoder output (B, len_keep+1, encoder_dim)
        ids_restore: (B, N)
        """
        B, _, _ = x.shape
        N = ids_restore.shape[1]
        
        # Embed tokens
        x = self.decoder_embed(x)  # (B, len_keep+1, decoder_dim)
        
        # Append mask tokens
        mask_tokens = self.mask_token.repeat(B, N + 1 - x.shape[1], 1)
        x_ = torch.cat([x[:, 1:, :], mask_tokens], dim=1)  # No cls token
        x_ = torch.gather(x_, dim=1, index=ids_restore.unsqueeze(-1).expand(-1, -1, x_.shape[-1]))
        x = torch.cat([x[:, :1, :], x_], dim=1)  # Add cls token back
        
        # Add positional embedding
        x = x + self.decoder_pos_embed
        
        # Transformer blocks
        for block in self.blocks:
            x = block(x)
        
        x = self.norm(x)
        x = self.pred(x)  # (B, N+1, patch_h * patch_w * C)
        
        # Remove cls token
        x = x[:, 1:, :]
        
        return x


class MAE(nn.Module):
    """Complete Masked Autoencoder for RTM pretraining."""
    
    def __init__(self, img_size=(128, 256), patch_size=(8, 16), in_chans=3,
                 embed_dim=768, encoder_depth=12, encoder_heads=12,
                 decoder_dim=512, decoder_depth=4, decoder_heads=8):
        super().__init__()
        
        self.patch_size = patch_size
        self.in_chans = in_chans
        
        self.encoder = MAEEncoder(
            img_size=img_size, patch_size=patch_size, in_chans=in_chans,
            embed_dim=embed_dim, depth=encoder_depth, num_heads=encoder_heads
        )
        
        self.decoder = MAEDecoder(
            num_patches=self.encoder.num_patches,
            patch_size=patch_size, in_chans=in_chans,
            encoder_dim=embed_dim, decoder_dim=decoder_dim,
            depth=decoder_depth, num_heads=decoder_heads
        )
    
    def patchify(self, imgs):
        """Convert images to patches."""
        B, C, H, W = imgs.shape
        pH, pW = self.patch_size
        nH, nW = H // pH, W // pW
        
        x = imgs.reshape(B, C, nH, pH, nW, pW)
        x = x.permute(0, 2, 4, 3, 5, 1).reshape(B, nH * nW, pH * pW * C)
        return x
    
    def forward(self, x, mask_ratio=0.75):
        """
        x: (B, C, H, W) - RTM input
        Returns: loss, reconstructed patches, mask
        """
        # Encode visible patches
        latent, mask, ids_restore = self.encoder(x, mask_ratio)
        
        # Decode (reconstruct all patches)
        pred = self.decoder(latent, ids_restore)
        
        # Target: original patches
        target = self.patchify(x)
        
        # MSE loss on masked patches only
        loss = (pred - target) ** 2
        loss = loss.mean(dim=-1)  # Per-patch loss
        loss = (loss * mask).sum() / mask.sum()  # Only masked patches
        
        return loss, pred, mask
    
    def get_encoder(self):
        """Extract encoder for downstream tasks."""
        return self.encoder


def train_mae(train_samples, config, device):
    """Phase 1: MAE Self-Supervised Pretraining."""
    print("\n" + "="*80)
    print("PHASE 1: MASKED AUTOENCODER PRETRAINING")
    print("="*80)
    
    # Dataset (no labels needed, no augmentation)
    dataset = RadarGestureDataset(
        train_samples, target_frames=config['target_frames'],
        augment=False, mode='mae'
    )
    loader = DataLoader(
        dataset, batch_size=config['mae_batch_size'],
        shuffle=True, num_workers=config['num_workers'],
        pin_memory=True, drop_last=True
    )
    
    # Create MAE
    mae = MAE(
        img_size=(config['target_frames'], config['range_bins']),
        patch_size=(8, 16), in_chans=3,
        embed_dim=768, encoder_depth=12, encoder_heads=12,
        decoder_dim=512, decoder_depth=4, decoder_heads=8
    ).to(device)
    
    n_params = sum(p.numel() for p in mae.parameters())
    print(f"MAE parameters: {n_params:,}")
    
    optimizer = AdamW(mae.parameters(), lr=config['mae_lr'],
                      weight_decay=0.05, betas=(0.9, 0.95))
    
    # Cosine schedule with warmup
    warmup_steps = config['mae_warmup_epochs'] * len(loader)
    total_steps = config['mae_epochs'] * len(loader)
    
    def lr_lambda(step):
        if step < warmup_steps:
            return step / warmup_steps
        progress = (step - warmup_steps) / (total_steps - warmup_steps)
        return 0.5 * (1 + math.cos(math.pi * progress))
    
    scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)
    scaler = GradScaler(enabled=config['use_amp'])
    
    # Training loop
    mae_losses = []
    
    for epoch in range(config['mae_epochs']):
        mae.train()
        epoch_loss = 0
        
        pbar = tqdm(loader, desc=f"MAE Epoch {epoch+1}/{config['mae_epochs']}")
        for x, _ in pbar:
            x = x.to(device)
            
            with autocast(enabled=config['use_amp']):
                loss, _, _ = mae(x, mask_ratio=config['mae_mask_ratio'])
            
            optimizer.zero_grad()
            scaler.scale(loss).backward()
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(mae.parameters(), config['gradient_clip'])
            scaler.step(optimizer)
            scaler.update()
            scheduler.step()
            
            epoch_loss += loss.item()
            pbar.set_postfix({'loss': f'{loss.item():.4f}', 'lr': f'{optimizer.param_groups[0]["lr"]:.2e}'})
        
        avg_loss = epoch_loss / len(loader)
        mae_losses.append(avg_loss)
        print(f"  MAE Epoch {epoch+1}: Loss = {avg_loss:.4f}")
    
    # Save MAE encoder weights
    torch.save({
        'encoder_state_dict': mae.encoder.state_dict(),
        'config': config
    }, OUTPUT_DIR / "mae_encoder.pth")
    
    # Plot MAE loss
    plt.figure(figsize=(10, 4))
    plt.plot(mae_losses, linewidth=2)
    plt.xlabel('Epoch')
    plt.ylabel('MAE Reconstruction Loss')
    plt.title('MAE Pretraining Loss')
    plt.grid(alpha=0.3)
    plt.savefig(OUTPUT_DIR / "mae_loss.png", dpi=150, bbox_inches='tight')
    plt.close()
    
    print(f"✓ MAE pretraining complete. Encoder saved.")
    
    return mae.encoder


