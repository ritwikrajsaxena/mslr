# BAYESIAN OPTIMIZATION
# ============================================================
def optuna_objective(trial, train_samples, config, device):
    clear_memory()
    
    lr = trial.suggest_float('lr', 5e-5, 5e-3, log=True)
    weight_decay = trial.suggest_float('weight_decay', 1e-6, 1e-2, log=True)
    dropout = trial.suggest_float('dropout', 0.15, 0.45)
    mixup_alpha = trial.suggest_float('mixup_alpha', 0.0, 0.5)
    label_smoothing = trial.suggest_float('label_smoothing', 0.05, 0.2)
    
    trial_config = {**config, 'dropout': dropout, 'lr': lr,
                    'weight_decay': weight_decay, 'mixup_alpha': mixup_alpha,
                    'label_smoothing': label_smoothing}
    
    labels = [s[1] for s in train_samples]
    sessions = [s[3] for s in train_samples]
    sgkf = StratifiedGroupKFold(n_splits=3, shuffle=True, random_state=42)
    train_idx, val_idx = next(sgkf.split(train_samples, labels, sessions))
    
    train_subset = [train_samples[i] for i in train_idx]
    val_subset = [train_samples[i] for i in val_idx]
    
    augmenter = RadarSpecAugment()
    train_ds = RadarGestureDataset(train_subset, target_frames=config['target_frames'],
                                    augment=True, augmenter=augmenter)
    val_ds = RadarGestureDataset(val_subset, target_frames=config['target_frames'], augment=False)
    
    train_loader = DataLoader(train_ds, batch_size=config['batch_size'], shuffle=True,
                              num_workers=config['num_workers'], pin_memory=True, drop_last=True)
    val_loader = DataLoader(val_ds, batch_size=config['batch_size'], shuffle=False,
                            num_workers=config['num_workers'], pin_memory=True)
    
    model = get_model('efficientnet', trial_config).to(device)
    criterion = nn.CrossEntropyLoss(label_smoothing=label_smoothing)
    optimizer = AdamW(model.parameters(), lr=lr, weight_decay=weight_decay)
    scheduler = CosineAnnealingWarmRestarts(optimizer, T_0=4, T_mult=2, eta_min=1e-7)
    scaler = GradScaler(enabled=config['use_amp'])
    
    best_val_acc = 0
    for epoch in range(config['optuna_epochs']):
        train_one_epoch(model, train_loader, criterion, optimizer, None,
                        scaler, device, trial_config)
        scheduler.step()
        _, val_acc = evaluate(model, val_loader, criterion, device, trial_config)
        best_val_acc = max(best_val_acc, val_acc)
        trial.report(val_acc, epoch)
        if trial.should_prune():
            del model, optimizer, scheduler, scaler
            clear_memory()
            raise optuna.TrialPruned()
    
    del model, optimizer, scheduler, scaler
    clear_memory()
    return best_val_acc


def run_bayesian_optimization(train_samples, config, device):
    print("\n" + "="*80)
    print("BAYESIAN HYPERPARAMETER OPTIMIZATION")
    print("="*80)
    
    study = optuna.create_study(direction='maximize',
                                sampler=TPESampler(seed=42),
                                pruner=optuna.pruners.MedianPruner(n_startup_trials=5))
    study.optimize(lambda t: optuna_objective(t, train_samples, config, device),
                   n_trials=config['n_optuna_trials'], show_progress_bar=True, gc_after_trial=True)
    
    print(f"\nBest trial: {study.best_trial.value:.4f}")
    for k, v in study.best_trial.params.items():
        print(f"  {k}: {v}")
    
    with open(OUTPUT_DIR / "optuna_best_params.json", 'w') as f:
        json.dump(study.best_trial.params, f, indent=2)
    
    return study.best_trial.params


