# --- 3A: Audio Spectrogram Transformer (AST) ---
class ASTModel(nn.Module):
    """Audio Spectrogram Transformer adapted for Radar RTMs."""
    
    def __init__(self, num_classes=126, dropout=0.3, img_size=(128, 256),
                 patch_size=(16, 16), embed_dim=768, depth=12, num_heads=12):
        super().__init__()
        
        self.patch_embed = PatchEmbed(img_size, patch_size, in_chans=3, embed_dim=embed_dim)
        num_patches = self.patch_embed.num_patches
        
        self.cls_token = nn.Parameter(torch.zeros(1, 1, embed_dim))
        self.dist_token = nn.Parameter(torch.zeros(1, 1, embed_dim))
        self.pos_embed = nn.Parameter(torch.zeros(1, num_patches + 2, embed_dim))
        
        self.blocks = nn.ModuleList([
            nn.TransformerEncoderLayer(
                d_model=embed_dim, nhead=num_heads,
                dim_feedforward=embed_dim * 4,
                dropout=0.1, activation='gelu', batch_first=True,
                norm_first=True
            )
            for _ in range(depth)
        ])
        
        self.norm = nn.LayerNorm(embed_dim)
        
        self.classifier = nn.Sequential(
            nn.LayerNorm(embed_dim * 2),
            nn.Dropout(dropout),
            nn.Linear(embed_dim * 2, 512),
            nn.GELU(),
            nn.Dropout(dropout / 2),
            nn.Linear(512, num_classes)
        )
        
        nn.init.trunc_normal_(self.cls_token, std=0.02)
        nn.init.trunc_normal_(self.dist_token, std=0.02)
        nn.init.trunc_normal_(self.pos_embed, std=0.02)
    
    def forward(self, x):
        B = x.shape[0]
        
        x = self.patch_embed(x)
        
        cls_tokens = self.cls_token.expand(B, -1, -1)
        dist_tokens = self.dist_token.expand(B, -1, -1)
        x = torch.cat([cls_tokens, dist_tokens, x], dim=1)
        
        x = x + self.pos_embed
        
        for block in self.blocks:
            x = block(x)
        
        x = self.norm(x)
        
        cls_out = x[:, 0]
        dist_out = x[:, 1]
        combined = torch.cat([cls_out, dist_out], dim=1)
        
        return self.classifier(combined)


# --- 3B: Multi-Stream Cross-Attention ---
class AntennaEncoder(nn.Module):
    """Single antenna stream encoder."""
    def __init__(self, embed_dim=256, pretrained=True):
        super().__init__()
        self.backbone = timm.create_model(
            'efficientnet_b2', pretrained=pretrained,
            num_classes=0, in_chans=1
        )
        self.feature_dim = self.backbone.num_features
        self.proj = nn.Linear(self.feature_dim, embed_dim)
    
    def forward(self, x):
        # x: (B, 1, T, R) single antenna
        features = self.backbone(x)  # (B, feature_dim)
        return self.proj(features)   # (B, embed_dim)


class CrossAttentionFusion(nn.Module):
    """Cross-attention between antenna streams."""
    
    def __init__(self, embed_dim=256, num_heads=8, num_layers=2):
        super().__init__()
        
        self.cross_attn_layers = nn.ModuleList([
            nn.MultiheadAttention(embed_dim, num_heads, batch_first=True)
            for _ in range(num_layers)
        ])
        
        self.norms = nn.ModuleList([
            nn.LayerNorm(embed_dim) for _ in range(num_layers)
        ])
        
        self.ffns = nn.ModuleList([
            nn.Sequential(
                nn.Linear(embed_dim, embed_dim * 4),
                nn.GELU(),
                nn.Linear(embed_dim * 4, embed_dim)
            )
            for _ in range(num_layers)
        ])
        
        self.ffn_norms = nn.ModuleList([
            nn.LayerNorm(embed_dim) for _ in range(num_layers)
        ])
    
    def forward(self, x):
        """
        x: (B, 3, embed_dim) - 3 antenna features stacked
        """
        for attn, norm, ffn, ffn_norm in zip(
            self.cross_attn_layers, self.norms, self.ffns, self.ffn_norms
        ):
            # Self-attention across antennas
            attn_out, _ = attn(x, x, x)
            x = norm(x + attn_out)
            
            ffn_out = ffn(x)
            x = ffn_norm(x + ffn_out)
        
        return x


class MultiStreamCrossAttentionModel(nn.Module):
    """Process each antenna separately, fuse with cross-attention."""
    
    def __init__(self, num_classes=126, embed_dim=256, dropout=0.3):
        super().__init__()
        
        # Separate encoders for each antenna
        self.encoder1 = AntennaEncoder(embed_dim)
        self.encoder2 = AntennaEncoder(embed_dim)
        self.encoder3 = AntennaEncoder(embed_dim)
        
        # Cross-attention fusion
        self.fusion = CrossAttentionFusion(embed_dim, num_heads=8, num_layers=2)
        
        # Classifier
        self.classifier = nn.Sequential(
            nn.LayerNorm(embed_dim * 3),
            nn.Dropout(dropout),
            nn.Linear(embed_dim * 3, 512),
            nn.GELU(),
            nn.Dropout(dropout / 2),
            nn.Linear(512, num_classes)
        )
    
    def forward(self, inputs):
        """
        inputs: tuple of (x1, x2, x3), each (B, 1, T, R)
        """
        if isinstance(inputs, (list, tuple)):
            x1, x2, x3 = inputs
        else:
            # If stacked input (B, 3, T, R), split
            x1 = inputs[:, 0:1, :, :]
            x2 = inputs[:, 1:2, :, :]
            x3 = inputs[:, 2:3, :, :]
        
        # Encode each antenna
        f1 = self.encoder1(x1)  # (B, embed_dim)
        f2 = self.encoder2(x2)
        f3 = self.encoder3(x3)
        
        # Stack for cross-attention
        fused = torch.stack([f1, f2, f3], dim=1)  # (B, 3, embed_dim)
        fused = self.fusion(fused)  # (B, 3, embed_dim)
        
        # Flatten and classify
        fused = fused.reshape(fused.shape[0], -1)  # (B, 3*embed_dim)
        return self.classifier(fused)


# --- 3C: EfficientNet-B4 with SupCon pretrained backbone ---
class EfficientNetB4Model(nn.Module):
    """EfficientNet-B4 (larger than B0, feasible on dream GPU)."""
    
    def __init__(self, num_classes=126, dropout=0.3, pretrained=True):
        super().__init__()
        self.backbone = timm.create_model(
            'efficientnet_b4', pretrained=pretrained,
            num_classes=0, in_chans=3
        )
        self.feature_dim = self.backbone.num_features
        self.classifier = nn.Sequential(
            nn.Dropout(dropout),
            nn.Linear(self.feature_dim, 512),
            nn.SiLU(),
            nn.Dropout(dropout / 2),
            nn.Linear(512, num_classes)
        )
    
    def forward(self, x):
        return self.classifier(self.backbone(x))
    
    def load_supcon_backbone(self, state_dict):
        """Load SupCon-pretrained backbone weights."""
        self.backbone.load_state_dict(state_dict, strict=False)
        print("  Loaded SupCon pretrained backbone")


# --- 3D: CRNN (CNN + BiGRU) ---
class CRNNModel(nn.Module):
    """CNN + BiGRU with attention pooling."""
    
    def __init__(self, num_classes=126, dropout=0.3, in_channels=3,
                 cnn_channels=[64, 128, 256], gru_hidden=256, gru_layers=2):
        super().__init__()
        
        self.cnn = nn.Sequential(
            nn.Conv1d(in_channels, cnn_channels[0], 7, stride=2, padding=3),
            nn.BatchNorm1d(cnn_channels[0]), nn.ReLU(True), nn.MaxPool1d(2),
            nn.Conv1d(cnn_channels[0], cnn_channels[1], 5, stride=2, padding=2),
            nn.BatchNorm1d(cnn_channels[1]), nn.ReLU(True), nn.MaxPool1d(2),
            nn.Conv1d(cnn_channels[1], cnn_channels[2], 3, stride=1, padding=1),
            nn.BatchNorm1d(cnn_channels[2]), nn.ReLU(True),
            nn.AdaptiveAvgPool1d(1),
        )
        
        self.gru = nn.GRU(cnn_channels[2], gru_hidden, gru_layers,
                          batch_first=True, bidirectional=True,
                          dropout=dropout if gru_layers > 1 else 0)
        
        self.attention = nn.Sequential(
            nn.Linear(gru_hidden * 2, 128), nn.Tanh(), nn.Linear(128, 1))
        
        self.classifier = nn.Sequential(
            nn.Dropout(dropout),
            nn.Linear(gru_hidden * 2, 256), nn.ReLU(True),
            nn.Dropout(dropout / 2),
            nn.Linear(256, num_classes)
        )
    
    def forward(self, x):
        B, C, T, R = x.shape
        x = x.permute(0, 2, 1, 3).reshape(B * T, C, R)
        x = self.cnn(x).squeeze(-1).reshape(B, T, -1)
        x, _ = self.gru(x)
        attn = F.softmax(self.attention(x), dim=1)
        x = (attn * x).sum(dim=1)
        return self.classifier(x)


# --- 3E: Student Model ---
class StudentModel(nn.Module):
    """Fast student model for distillation."""
    def __init__(self, num_classes=126, dropout=0.2):
        super().__init__()
        self.backbone = timm.create_model(
            'efficientnet_b0', pretrained=True, num_classes=0, in_chans=3)
        self.feature_dim = self.backbone.num_features
        self.classifier = nn.Sequential(
            nn.Dropout(dropout),
            nn.Linear(self.feature_dim, 256),
            nn.SiLU(),
            nn.Linear(256, num_classes)
        )
    
    def forward(self, x):
        return self.classifier(self.backbone(x))


def get_model(model_type, config, supcon_backbone=None):
    """Model factory."""
    if model_type == 'ast':
        return ASTModel(config['num_classes'], config.get('dropout', 0.3),
                        img_size=(config['target_frames'], config['range_bins']))
    elif model_type == 'multistream':
        return MultiStreamCrossAttentionModel(config['num_classes'], dropout=config.get('dropout', 0.3))
    elif model_type == 'efficientnet':
        model = EfficientNetB4Model(config['num_classes'], config.get('dropout', 0.3))
        if supcon_backbone is not None:
            model.load_supcon_backbone(supcon_backbone)
        return model
    elif model_type == 'crnn':
        return CRNNModel(config['num_classes'], config.get('dropout', 0.3))
    elif model_type == 'student':
        return StudentModel(config['num_classes'])
    else:
        raise ValueError(f"Unknown model: {model_type}")


