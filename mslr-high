class RadarGestureDataset(Dataset):
    """Dataset supporting all training modes: MAE, SupCon, Classification, Distillation."""
    
    def __init__(self, samples, target_frames=128, augment=False,
                 augmenter=None, is_test=False, soft_labels=None,
                 mode='classification', return_separate_antennas=False):
        """
        mode: 'classification' | 'mae' | 'supcon' | 'distillation'
        return_separate_antennas: If True, return (rtm1, rtm2, rtm3) separately
        """
        self.samples = samples
        self.target_frames = target_frames
        self.augment = augment
        self.augmenter = augmenter if augmenter else RadarSpecAugment()
        self.strong_augmenter = RadarSpecAugment(strong=True)
        self.is_test = is_test
        self.soft_labels = soft_labels
        self.mode = mode
        self.return_separate_antennas = return_separate_antennas
    
    def __len__(self):
        return len(self.samples)
    
    def _load_rtm(self, npy_path):
        return np.load(npy_path).astype(np.float32)
    
    def _resize_temporal(self, rtm):
        T, R = rtm.shape
        if T == self.target_frames:
            return rtm
        t = torch.tensor(rtm, dtype=torch.float32).unsqueeze(0).unsqueeze(0)
        t = F.interpolate(t, size=(self.target_frames, R), mode='bilinear', align_corners=False)
        return t.squeeze().numpy()
    
    def _normalize(self, rtm):
        return (rtm - rtm.mean()) / (rtm.std() + 1e-8)
    
    def _load_single_rtm(self, sample_dir, rtm_name, apply_aug=True):
        """Load, resize, normalize, and optionally augment a single RTM."""
        npy_files = list(sample_dir.glob(f"*_{rtm_name}.npy"))
        if npy_files:
            rtm = self._load_rtm(npy_files[0])
            rtm = self._resize_temporal(rtm)
            rtm = self._normalize(rtm)
            if apply_aug and self.augment:
                rtm = self.augmenter(rtm)
            return rtm
        return np.zeros((self.target_frames, 256), dtype=np.float32)
    
    def __getitem__(self, idx):
        sample_dir, label, sample_id, session_id = self.samples[idx]
        
        if self.mode == 'supcon':
            # SupCon: Return two augmented views of the same sample
            rtms_view1 = []
            rtms_view2 = []
            for name in ["RTM1", "RTM2", "RTM3"]:
                npy_files = list(sample_dir.glob(f"*_{name}.npy"))
                if npy_files:
                    rtm = self._load_rtm(npy_files[0])
                    rtm = self._resize_temporal(rtm)
                    rtm = self._normalize(rtm)
                    
                    view1 = self.augmenter(rtm.copy())
                    view2 = self.strong_augmenter(rtm.copy())
                    
                    rtms_view1.append(view1)
                    rtms_view2.append(view2)
                else:
                    z = np.zeros((self.target_frames, 256), dtype=np.float32)
                    rtms_view1.append(z)
                    rtms_view2.append(z)
            
            x1 = torch.tensor(np.stack(rtms_view1, axis=0), dtype=torch.float32)
            x2 = torch.tensor(np.stack(rtms_view2, axis=0), dtype=torch.float32)
            y = torch.tensor(label, dtype=torch.long)
            
            return x1, x2, y, sample_id
        
        elif self.mode == 'mae':
            # MAE: Return unaugmented sample for reconstruction
            rtms = []
            for name in ["RTM1", "RTM2", "RTM3"]:
                rtms.append(self._load_single_rtm(sample_dir, name, apply_aug=False))
            
            x = torch.tensor(np.stack(rtms, axis=0), dtype=torch.float32)
            return x, sample_id
        
        else:
            # Classification or Distillation
            if self.return_separate_antennas:
                # For Multi-Stream Cross-Attention model
                rtm1 = self._load_single_rtm(sample_dir, "RTM1")
                rtm2 = self._load_single_rtm(sample_dir, "RTM2")
                rtm3 = self._load_single_rtm(sample_dir, "RTM3")
                
                x1 = torch.tensor(rtm1, dtype=torch.float32).unsqueeze(0)  # (1, T, R)
                x2 = torch.tensor(rtm2, dtype=torch.float32).unsqueeze(0)
                x3 = torch.tensor(rtm3, dtype=torch.float32).unsqueeze(0)
                
                y = torch.tensor(label if not self.is_test else -1, dtype=torch.long)
                
                if self.soft_labels is not None:
                    soft_y = torch.tensor(self.soft_labels[idx], dtype=torch.float32)
                    return (x1, x2, x3), y, soft_y, sample_id
                
                return (x1, x2, x3), y, sample_id
            else:
                # Standard stacked input
                rtms = []
                for name in ["RTM1", "RTM2", "RTM3"]:
                    rtms.append(self._load_single_rtm(sample_dir, name))
                
                x = torch.tensor(np.stack(rtms, axis=0), dtype=torch.float32)
                y = torch.tensor(label if not self.is_test else -1, dtype=torch.long)
                
                if self.soft_labels is not None:
                    soft_y = torch.tensor(self.soft_labels[idx], dtype=torch.float32)
                    return x, y, soft_y, sample_id
                
                return x, y, sample_id


def load_all_samples(root):
    """Load all dataset samples with session information."""
    train_path = root / "train"
    val_path = root / "val"
    test_path = root / "test"
    
    train_samples = []
    class_to_idx = {}
    class_samples = defaultdict(list)
    
    for cls_dir in sorted(train_path.iterdir()):
        if not cls_dir.is_dir(): continue
        cls_name = cls_dir.name
        cls_id = int(cls_name.split("_")[0])
        class_to_idx[cls_name] = cls_id
        
        for sample_dir in sorted(cls_dir.iterdir()):
            if sample_dir.is_dir():
                sample_id = int(sample_dir.name.replace("SAMPLE_", ""))
                class_samples[cls_id].append((sample_dir, cls_id, sample_id))
    
    for cls_id, samples in class_samples.items():
        for session_idx, (sample_dir, label, sample_id) in enumerate(samples):
            train_samples.append((sample_dir, label, sample_id, session_idx))
    
    val_samples = []
    for sample_dir in sorted(val_path.iterdir()):
        if sample_dir.is_dir():
            sample_id = int(sample_dir.name.replace("SAMPLE_", ""))
            val_samples.append((sample_dir, -1, sample_id, -1))
    
    test_samples = []
    for sample_dir in sorted(test_path.iterdir()):
        if sample_dir.is_dir():
            sample_id = int(sample_dir.name.replace("SAMPLE_", ""))
            test_samples.append((sample_dir, -1, sample_id, -1))
    
    print(f"Training: {len(train_samples)}, Val: {len(val_samples)}, Test: {len(test_samples)}")
    print(f"Classes: {len(class_to_idx)}")
    
    return train_samples, val_samples, test_samples, class_to_idx


