# PHASE 3: K-FOLD FINE-TUNING
# ============================================================
def train_kfold(model_type, train_samples, config, device, best_params=None,
                supcon_backbone=None):
    print(f"\n{'='*80}")
    print(f"TRAINING {model_type.upper()} WITH {config['n_folds']}-FOLD CV")
    print(f"{'='*80}")
    
    train_config = {**config}
    if best_params:
        train_config.update(best_params)
    
    labels = [s[1] for s in train_samples]
    sessions = [s[3] for s in train_samples]
    sgkf = StratifiedGroupKFold(n_splits=config['n_folds'], shuffle=True, random_state=42)
    
    is_multistream = (model_type == 'multistream')
    augmenter = RadarSpecAugment()
    
    fold_models = []
    fold_scores = []
    
    for fold, (train_idx, val_idx) in enumerate(sgkf.split(train_samples, labels, sessions)):
        print(f"\n--- Fold {fold+1}/{config['n_folds']} ---")
        clear_memory()
        
        train_subset = [train_samples[i] for i in train_idx]
        val_subset = [train_samples[i] for i in val_idx]
        
        train_ds = RadarGestureDataset(
            train_subset, target_frames=config['target_frames'],
            augment=True, augmenter=augmenter,
            return_separate_antennas=is_multistream
        )
        val_ds = RadarGestureDataset(
            val_subset, target_frames=config['target_frames'],
            augment=False, return_separate_antennas=is_multistream
        )
        
        train_loader = DataLoader(train_ds, batch_size=config['batch_size'],
                                  shuffle=True, num_workers=config['num_workers'],
                                  pin_memory=True, drop_last=True)
        val_loader = DataLoader(val_ds, batch_size=config['batch_size'],
                                shuffle=False, num_workers=config['num_workers'],
                                pin_memory=True)
        
        model = get_model(model_type, train_config, supcon_backbone).to(device)
        
        criterion = nn.CrossEntropyLoss(label_smoothing=train_config.get('label_smoothing', 0.1))
        optimizer = AdamW(model.parameters(), lr=train_config.get('lr', config['finetune_lr']),
                          weight_decay=train_config.get('weight_decay', 1e-4))
        
        total_steps = len(train_loader) * config['finetune_epochs']
        scheduler = OneCycleLR(optimizer, max_lr=train_config.get('lr', config['finetune_lr']),
                               total_steps=total_steps, pct_start=0.1)
        
        scaler = GradScaler(enabled=config['use_amp'])
        early_stopping = EarlyStopping(patience=config['early_stopping_patience'], mode='max')
        
        best_val_acc = 0
        
        pbar = tqdm(range(config['finetune_epochs']), desc=f"Fold {fold+1}")
        for epoch in pbar:
            train_loss, train_acc = train_one_epoch(
                model, train_loader, criterion, optimizer, scheduler,
                scaler, device, train_config, is_multistream
            )
            val_loss, val_acc = evaluate(
                model, val_loader, criterion, device, train_config, is_multistream
            )
            
            best_val_acc = max(best_val_acc, val_acc)
            pbar.set_postfix({'tr': f'{train_acc*100:.1f}%', 'val': f'{val_acc*100:.1f}%',
                              'best': f'{best_val_acc*100:.1f}%'})
            
            if early_stopping(val_acc, model):
                print(f"  Early stopping at epoch {epoch+1}")
                break
        
        early_stopping.load_best_model(model)
        print(f"  Fold {fold+1} Best Val Acc: {best_val_acc*100:.2f}%")
        
        model.cpu()
        fold_models.append((copy.deepcopy(model), best_val_acc))
        fold_scores.append(best_val_acc)
        
        torch.save({'model_state_dict': model.state_dict(), 'val_acc': best_val_acc},
                   OUTPUT_DIR / f"{model_type}_fold{fold}.pth")
        
        del model, optimizer, scheduler, scaler
        clear_memory()
    
    print(f"\n{model_type.upper()} CV: {np.mean(fold_scores)*100:.2f}% ± {np.std(fold_scores)*100:.2f}%")
    return fold_models


