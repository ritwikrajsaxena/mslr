# PHASE 5: KNOWLEDGE DISTILLATION
# ============================================================
def train_student_distillation(train_samples, soft_labels, config, best_params, device):
    print("\n" + "="*80)
    print("PHASE 5: KNOWLEDGE DISTILLATION")
    print("="*80)
    
    clear_memory()
    train_config = {**config, **best_params}
    
    n_val = int(0.1 * len(train_samples))
    indices = list(range(len(train_samples)))
    random.shuffle(indices)
    
    train_subset = [train_samples[i] for i in indices[n_val:]]
    val_subset = [train_samples[i] for i in indices[:n_val]]
    train_soft = soft_labels[indices[n_val:]]
    val_soft = soft_labels[indices[:n_val]]
    
    train_ds = RadarGestureDataset(train_subset, target_frames=config['target_frames'],
                                    augment=True, soft_labels=train_soft, mode='distillation')
    val_ds = RadarGestureDataset(val_subset, target_frames=config['target_frames'],
                                  augment=False, soft_labels=val_soft, mode='distillation')
    
    train_loader = DataLoader(train_ds, batch_size=config['batch_size'],
                              shuffle=True, num_workers=config['num_workers'],
                              pin_memory=True, drop_last=True)
    val_loader = DataLoader(val_ds, batch_size=config['batch_size'],
                            shuffle=False, num_workers=config['num_workers'],
                            pin_memory=True)
    
    student = get_model('student', train_config).to(device)
    
    optimizer = AdamW(student.parameters(), lr=train_config.get('lr', 5e-4) * 0.5,
                      weight_decay=train_config.get('weight_decay', 1e-4))
    scheduler = CosineAnnealingWarmRestarts(optimizer, T_0=10, T_mult=2, eta_min=1e-7)
    scaler = GradScaler(enabled=config['use_amp'])
    early_stopping = EarlyStopping(patience=config['early_stopping_patience'], mode='max')
    
    T = config['distill_temperature']
    alpha = config['distill_alpha']
    best_val_acc = 0
    
    for epoch in tqdm(range(config['distill_epochs']), desc="Distillation"):
        student.train()
        for x, y, soft_y, _ in train_loader:
            x, y, soft_y = x.to(device), y.to(device), soft_y.to(device)
            
            with autocast(enabled=config['use_amp']):
                logits = student(x)
                hard_loss = F.cross_entropy(logits, y)
                soft_loss = F.kl_div(F.log_softmax(logits / T, dim=1), soft_y,
                                     reduction='batchmean') * (T ** 2)
                loss = alpha * soft_loss + (1 - alpha) * hard_loss
            
            optimizer.zero_grad()
            scaler.scale(loss).backward()
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(student.parameters(), config['gradient_clip'])
            scaler.step(optimizer)
            scaler.update()
        
        scheduler.step()
        
        student.eval()
        val_correct, val_total = 0, 0
        with torch.no_grad():
            for x, y, _, _ in val_loader:
                x, y = x.to(device), y.to(device)
                logits = student(x)
                val_correct += (logits.argmax(dim=1) == y).sum().item()
                val_total += x.size(0)
        
        val_acc = val_correct / val_total
        if val_acc > best_val_acc:
            best_val_acc = val_acc
            torch.save({'model_state_dict': student.state_dict()}, OUTPUT_DIR / "student_best.pth")
        
        if early_stopping(val_acc, student):
            break
    
    early_stopping.load_best_model(student)
    print(f"\nStudent Best Val Acc: {best_val_acc*100:.2f}%")
    return student


