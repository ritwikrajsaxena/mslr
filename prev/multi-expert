def scan_dataset(folder, labeled=True):
    samples = []
    if not folder.exists():
        return samples
    for cls_dir in sorted(folder.iterdir()):
        if not cls_dir.is_dir():
            continue
        label = first_int(cls_dir.name, -1) if labeled else -1
        if labeled and (label < 0 or label >= cfg.num_classes):
            continue
        for sample_dir in sorted(cls_dir.iterdir()):
            if sample_dir.is_dir() and any(sample_dir.glob("*.npy")):
                sid = first_int(sample_dir.name, len(samples))
                samples.append((sample_dir, label, sid, sid))
    return samples

def load_data(cfg):
    print("Loading dataset...")
    train_samples = scan_dataset(cfg.root_dir / "train", labeled=True)
    val_samples = scan_dataset(cfg.root_dir / "val", labeled=False)
    test_samples = scan_dataset(cfg.root_dir / "test", labeled=False)
    print(f"  Train: {len(train_samples)}, Val: {len(val_samples)}, Test: {len(test_samples)}")
    if len(train_samples) == 0:
        raise ValueError("No training samples found!")
    labels = [s[1] for s in train_samples]
    print(f"  Classes: {len(set(labels))}")
    return train_samples, val_samples, test_samples

def get_class_weights(labels, num_classes):
    counts = Counter(labels)
    total = len(labels)
    weights = []
    for i in range(num_classes):
        count = counts.get(i, 0)
        weights.append(total / (num_classes * count) if count > 0 else 1.0)
    return torch.tensor(weights, dtype=torch.float32)

