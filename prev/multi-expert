class EfficientNetExpert(nn.Module):
    def __init__(self, cfg):
        super().__init__()
        self.cfg = cfg
        
        # Use EfficientNet-B2 for better capacity
        self.backbone = timm.create_model(
            "efficientnet_b2", pretrained=cfg.pretrained, num_classes=0, in_chans=3
        )
        feat_dim = self.backbone.num_features  # 1408 for B2
        
        self.proj = nn.Sequential(
            nn.Linear(feat_dim, cfg.proj_dim),
            nn.LayerNorm(cfg.proj_dim),
            nn.GELU(),
            nn.Dropout(0.1)
        )
        
        self.temporal = TemporalLSTM(
            cfg.proj_dim, cfg.lstm_hidden, cfg.lstm_layers, cfg.num_classes, cfg.dropout
        )
    
    def forward(self, x):
        B, C, T, R = x.shape
        
        # Process all frames at once (no chunking - we have memory)
        x = x.permute(0, 2, 1, 3).reshape(B * T, C, R)  # [B*T, C, R]
        x = x.unsqueeze(-1).expand(-1, -1, -1, self.cfg.img_size)  # [B*T, C, R, img_size]
        x = F.interpolate(x, size=(self.cfg.img_size, self.cfg.img_size), 
                         mode="bilinear", align_corners=False)
        
        with torch.cuda.amp.autocast(enabled=amp_enabled):
            feats = self.backbone(x)  # [B*T, feat_dim]
            feats = self.proj(feats)  # [B*T, proj_dim]
        
        feats = feats.reshape(B, T, -1)  # [B, T, proj_dim]
        return self.temporal(feats)

class SwinExpert(nn.Module):
    def __init__(self, cfg):
        super().__init__()
        self.cfg = cfg
        
        self.backbone = timm.create_model(
            "swin_tiny_patch4_window7_224", pretrained=cfg.pretrained, num_classes=0, in_chans=3
        )
        feat_dim = self.backbone.num_features  # 768
        
        self.proj = nn.Sequential(
            nn.Linear(feat_dim, cfg.proj_dim),
            nn.LayerNorm(cfg.proj_dim),
            nn.GELU(),
            nn.Dropout(0.1)
        )
        
        self.temporal = TemporalTransformer(
            cfg.proj_dim, cfg.transformer_heads, cfg.transformer_layers, 
            cfg.num_classes, cfg.dropout
        )
    
    def forward(self, x):
        B, C, T, R = x.shape
        
        x = x.permute(0, 2, 1, 3).reshape(B * T, C, R)
        x = x.unsqueeze(-1).expand(-1, -1, -1, self.cfg.img_size)
        x = F.interpolate(x, size=(self.cfg.img_size, self.cfg.img_size),
                         mode="bilinear", align_corners=False)
        
        with torch.cuda.amp.autocast(enabled=amp_enabled):
            feats = self.backbone(x)
            feats = self.proj(feats)
        
        feats = feats.reshape(B, T, -1)
        return self.temporal(feats)

