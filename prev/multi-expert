# PSEUDO-LABELING
# ============================================================
@torch.no_grad()
def generate_pseudo_labels(checkpoints, samples, cfg, device):
    if len(samples) == 0 or len(checkpoints) == 0:
        return []
    
    print(f"\nGenerating pseudo-labels on {len(samples)} samples...")
    print_memory_stats("Before: ")
    
    ds = RadarDataset(samples, cfg, augment=False, is_test=True)
    dl = DataLoader(ds, batch_size=cfg.batch_size_infer, shuffle=False,
                   num_workers=cfg.num_workers, pin_memory=cfg.pin_memory)
    
    all_preds, all_confs = [], []
    
    for ckpt in tqdm(checkpoints, desc="Model Inference"):
        model = None
        try:
            model = get_expert(ckpt["expert_name"], cfg).to(device)
            model.load_state_dict(ckpt["state_dict"])
            model.eval()
            
            preds, confs = [], []
            for batch in dl:
                x = batch["rtm"].to(device, non_blocking=True)
                with autocast(enabled=amp_enabled):
                    logits = model(x)
                    probs = F.softmax(logits, dim=1)
                preds.extend(logits.argmax(1).cpu().numpy())
                confs.extend(probs.max(1)[0].cpu().numpy())
                del x, logits, probs
            
            all_preds.append(preds)
            all_confs.append(confs)
        finally:
            if model:
                model.cpu()
                del model
            clear_memory()
    
    del dl, ds
    clear_memory()
    
    pseudo_samples = []
    min_agree = min(cfg.pseudo_min_vote_agreement, len(checkpoints))
    
    for i in range(len(samples)):
        votes = [all_preds[m][i] for m in range(len(checkpoints))]
        confidences = [all_confs[m][i] for m in range(len(checkpoints))]
        
        vote_counts = Counter(votes)
        top_cls, count = vote_counts.most_common(1)[0]
        
        winning_confs = [confidences[m] for m in range(len(checkpoints)) if votes[m] == top_cls]
        avg_conf = np.mean(winning_confs)
        
        if count >= min_agree and avg_conf >= cfg.pseudo_confidence_threshold:
            sample_dir, _, sample_id, group_id = samples[i]
            pseudo_samples.append((sample_dir, int(top_cls), sample_id, group_id))
    
    print(f"Accepted: {len(pseudo_samples)}/{len(samples)} ({100*len(pseudo_samples)/max(1,len(samples)):.1f}%)")
    return pseudo_samples

