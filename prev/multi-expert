# ENSEMBLE INFERENCE
# ============================================================
@torch.no_grad()
def ensemble_predict(checkpoints, samples, cfg, device):
    if len(samples) == 0:
        return np.array([]), []
    
    print(f"\nEnsemble inference on {len(samples)} samples...")
    
    ds = RadarDataset(samples, cfg, augment=False, is_test=True)
    dl = DataLoader(ds, batch_size=cfg.batch_size_infer, shuffle=False,
                   num_workers=cfg.num_workers, pin_memory=cfg.pin_memory)
    
    weights = np.array([ckpt["best_val_acc"] for ckpt in checkpoints])
    weights = weights / weights.sum()
    
    num_samples = len(samples)
    ensemble_probs = torch.zeros(num_samples, cfg.num_classes, dtype=torch.float32)
    sample_ids = []
    
    for ckpt_idx, ckpt in enumerate(tqdm(checkpoints, desc="Ensemble")):
        model = None
        try:
            model = get_expert(ckpt["expert_name"], cfg).to(device)
            model.load_state_dict(ckpt["state_dict"])
            model.eval()
            
            batch_start = 0
            for batch in dl:
                x = batch["rtm"].to(device, non_blocking=True)
                batch_size = x.size(0)
                
                if ckpt_idx == 0:
                    sample_ids.extend([int(sid) for sid in batch["sample_id"]])
                
                with autocast(enabled=amp_enabled):
                    logits = model(x)
                    probs = F.softmax(logits, dim=1)
                
                ensemble_probs[batch_start:batch_start + batch_size] += weights[ckpt_idx] * probs.cpu()
                batch_start += batch_size
                del x, logits, probs
        finally:
            if model:
                model.cpu()
                del model
            clear_memory()
    
    del dl, ds
    clear_memory()
    
    return ensemble_probs.argmax(dim=1).numpy(), sample_ids

# ============================================================
# MAIN PIPELINE
# ============================================================
def main():
    pipeline_start = time.time()
    print_memory_stats("Initial: ")
    
    train_samples, val_samples, test_samples = load_data(cfg)
    
    indices = np.arange(len(train_samples))
    labels = np.array([s[1] for s in train_samples])
    
    if cfg.n_folds == 1:
        train_idx, val_idx = train_test_split(indices, test_size=0.2, random_state=cfg.seed, stratify=labels)
        splits = [(train_idx, val_idx)]
    else:
        skf = StratifiedKFold(n_splits=cfg.n_folds, shuffle=True, random_state=cfg.seed)
        splits = list(skf.split(indices, labels))
    
    all_checkpoints = []
    expert_results = {}
    
    for expert_idx, expert_name in enumerate(cfg.experts):
        print(f"\n{'#'*60}")
        print(f"# EXPERT {expert_idx + 1}/{len(cfg.experts)}: {expert_name.upper()}")
        print(f"{'#'*60}")
        
        expert_ckpts = []
        
        for fold, (train_idx, val_idx) in enumerate(splits):
            fold_train = [train_samples[i] for i in train_idx]
            fold_val = [train_samples[i] for i in val_idx]
            
            result = train_model(cfg, fold_train, fold_val, expert_name, fold, device)
            expert_ckpts.append(result)
            all_checkpoints.append(result)
            
            print(f"\n--- Cleanup after {expert_name} Fold {fold + 1} ---")
            clear_memory(verbose=True)
        
        avg_acc = np.mean([r["best_val_acc"] for r in expert_ckpts])
        avg_top5 = np.mean([r["best_top5"] for r in expert_ckpts])
        expert_results[expert_name] = {"acc": avg_acc, "top5": avg_top5}
        print(f"\n{expert_name.upper()} Average: {avg_acc*100:.2f}% (Top5: {avg_top5*100:.2f}%)")
        
        gc.collect()
        torch.cuda.empty_cache()
        time.sleep(1)
    
    print("\n" + "=" * 50)
    print("EXPERT COMPARISON")
    print("=" * 50)
    for name, metrics in sorted(expert_results.items(), key=lambda x: -x[1]["acc"]):
        print(f"  {name.upper():15s}: {metrics['acc']*100:.2f}% (Top5: {metrics['top5']*100:.2f}%)")
    
    if cfg.enable_pseudo_labeling and (len(val_samples) > 0 or len(test_samples) > 0):
        print("\n" + "=" * 50)
        print("PSEUDO-LABELING")
        print("=" * 50)
        
        pseudo_val = generate_pseudo_labels(all_checkpoints, val_samples, cfg, device)
        clear_memory(verbose=True)
        
        pseudo_test = generate_pseudo_labels(all_checkpoints, test_samples, cfg, device)
        clear_memory(verbose=True)
        
        if len(pseudo_val) > 0 or len(pseudo_test) > 0:
            expanded_train = train_samples + pseudo_val + pseudo_test
            print(f"Expanded: {len(train_samples)} + {len(pseudo_val)} + {len(pseudo_test)} = {len(expanded_train)}")
            
            best_expert = max(expert_results.items(), key=lambda x: x[1]["acc"])[0]
            print(f"\nRetraining {best_expert.upper()}...")
            
            exp_labels = [s[1] for s in expanded_train]
            train_idx, val_idx = train_test_split(
                np.arange(len(expanded_train)), test_size=0.1,
                random_state=cfg.seed, stratify=exp_labels
            )
            
            result = train_model(
                cfg, [expanded_train[i] for i in train_idx],
                [expanded_train[i] for i in val_idx],
                best_expert, 99, device
            )
            all_checkpoints.append(result)
            clear_memory(verbose=True)
    
    if len(test_samples) > 0:
        print("\n" + "=" * 50)
        print("FINAL INFERENCE")
        print("=" * 50)
        
        predictions, sample_ids = ensemble_predict(all_checkpoints, test_samples, cfg, device)
        
        submission_path = cfg.output_dir / "submission.csv"
        df = pd.DataFrame({"sample_id": sample_ids, "prediction": predictions})
        df.to_csv(submission_path, index=False)
        print(f"Saved: {submission_path}")
        clear_memory(verbose=True)
    
    # Save summary
    summary = {
        "experts": {k: v for k, v in expert_results.items()},
        "checkpoints": [
            {"expert": c["expert_name"], "fold": c["fold"], 
             "acc": c["best_val_acc"], "top5": c["best_top5"]}
            for c in all_checkpoints
        ]
    }
    with open(cfg.output_dir / "training_summary.json", 'w') as f:
        json.dump(summary, f, indent=2)
    
    total_time = time.time() - pipeline_start
    print("\n" + "=" * 60)
    print("✅ PIPELINE COMPLETE")
    print("=" * 60)
    print(f"Total time: {format_time(total_time)}")
    print(f"Models trained: {len(all_checkpoints)}")
    best = max(expert_results.items(), key=lambda x: x[1]["acc"])
    print(f"Best expert: {best[0].upper()} ({best[1]['acc']*100:.2f}%)")
    print_memory_stats("Final: ")
    print("=" * 60)
    
    return all_checkpoints, expert_results

