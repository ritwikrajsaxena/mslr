def mixup_data(x, y, alpha=0.3):
    lam = np.random.beta(alpha, alpha) if alpha > 0 else 1.0
    lam = max(lam, 1 - lam)  # Ensure lam >= 0.5
    idx = torch.randperm(x.size(0), device=x.device)
    mixed_x = lam * x + (1 - lam) * x[idx]
    return mixed_x, y, y[idx], lam

def cutmix_data(x, y, alpha=1.0):
    lam = np.random.beta(alpha, alpha)
    B, C, T, R = x.size()
    
    # Random box
    cut_rat = np.sqrt(1. - lam)
    cut_t = int(T * cut_rat)
    cut_r = int(R * cut_rat)
    
    ct = np.random.randint(T)
    cr = np.random.randint(R)
    
    t1 = np.clip(ct - cut_t // 2, 0, T)
    t2 = np.clip(ct + cut_t // 2, 0, T)
    r1 = np.clip(cr - cut_r // 2, 0, R)
    r2 = np.clip(cr + cut_r // 2, 0, R)
    
    idx = torch.randperm(B, device=x.device)
    x_cut = x.clone()
    x_cut[:, :, t1:t2, r1:r2] = x[idx, :, t1:t2, r1:r2]
    
    lam = 1 - ((t2 - t1) * (r2 - r1) / (T * R))
    
    return x_cut, y, y[idx], lam

def train_one_epoch(model, loader, criterion, optimizer, scheduler, scaler, cfg, device, epoch):
    model.train()
    loss_meter = AverageMeter()
    acc_meter = AverageMeter()
    
    optimizer.zero_grad(set_to_none=True)
    pbar = tqdm(loader, desc=f"Train Epoch {epoch}", leave=False)
    
    for batch_idx, batch in enumerate(pbar):
        x = batch["rtm"].to(device, non_blocking=True)
        y = batch["label"].to(device, non_blocking=True)
        
        # Augmentation selection
        aug_type = random.random()
        
        if aug_type < 0.3 and x.size(0) > 1:  # Mixup 30%
            x, ya, yb, lam = mixup_data(x, y, cfg.mixup_alpha)
            with autocast(enabled=amp_enabled):
                logits = model(x)
                loss = lam * criterion(logits, ya) + (1 - lam) * criterion(logits, yb)
            pred = logits.argmax(dim=1)
            acc = (lam * (pred == ya).float() + (1 - lam) * (pred == yb).float()).mean()
            
        elif aug_type < 0.45 and x.size(0) > 1:  # CutMix 15%
            x, ya, yb, lam = cutmix_data(x, y)
            with autocast(enabled=amp_enabled):
                logits = model(x)
                loss = lam * criterion(logits, ya) + (1 - lam) * criterion(logits, yb)
            pred = logits.argmax(dim=1)
            acc = (lam * (pred == ya).float() + (1 - lam) * (pred == yb).float()).mean()
            
        else:  # Normal
            with autocast(enabled=amp_enabled):
                logits = model(x)
                loss = criterion(logits, y)
            pred = logits.argmax(dim=1)
            acc = (pred == y).float().mean()
        
        # Gradient accumulation
        loss_scaled = loss / cfg.accumulation_steps
        scaler.scale(loss_scaled).backward()
        
        if ((batch_idx + 1) % cfg.accumulation_steps == 0) or ((batch_idx + 1) == len(loader)):
            scaler.unscale_(optimizer)
            nn.utils.clip_grad_norm_(model.parameters(), cfg.gradient_clip)
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad(set_to_none=True)
            if scheduler is not None:
                scheduler.step()
        
        loss_meter.update(loss.item(), x.size(0))
        acc_meter.update(acc.item(), x.size(0))
        pbar.set_postfix(loss=f"{loss_meter.avg:.4f}", acc=f"{acc_meter.avg*100:.1f}%")
        
        del x, y, logits, loss, pred
    
    return {"train_loss": loss_meter.avg, "train_acc": acc_meter.avg}

@torch.no_grad()
def validate(model, loader, criterion, cfg, device):
    model.eval()
    all_preds, all_labels, all_probs = [], [], []
    total_loss, total_samples = 0.0, 0
    
    for batch in tqdm(loader, desc="Validation", leave=False):
        x = batch["rtm"].to(device, non_blocking=True)
        y = batch["label"].to(device, non_blocking=True)
        
        with autocast(enabled=amp_enabled):
            logits = model(x)
            loss = criterion(logits, y)
        
        probs = F.softmax(logits, dim=1)
        preds = logits.argmax(dim=1)
        
        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(y.cpu().numpy())
        all_probs.extend(probs.cpu().numpy())
        total_loss += loss.item() * x.size(0)
        total_samples += x.size(0)
        
        del x, y, logits, loss, preds, probs
    
    all_probs = np.array(all_probs)
    acc = accuracy_score(all_labels, all_preds)
    f1 = f1_score(all_labels, all_preds, average='macro', zero_division=0)
    
    try:
        top5 = top_k_accuracy_score(all_labels, all_probs, k=5, labels=range(cfg.num_classes))
    except:
        top5 = 0.0
    
    return {
        "val_loss": total_loss / max(1, total_samples),
        "val_acc": acc,
        "val_f1": f1,
        "val_top5": top5
    }

def train_model(cfg, train_samples, val_samples, expert_name, fold, device):
    print(f"\n{'='*50}")
    print(f"Training {expert_name.upper()} - Fold {fold + 1}/{cfg.n_folds}")
    print_memory_stats("Before: ")
    print(f"{'='*50}")
    
    clear_memory(verbose=False)
    
    model = optimizer = scheduler = scaler = None
    train_loader = val_loader = train_ds = val_ds = None
    
    try:
        bs = cfg.batch_size_3d if expert_name in ["r3d", "mc3", "r2plus1d"] else cfg.batch_size_2d
        
        train_ds = RadarDataset(train_samples, cfg, augment=True)
        val_ds = RadarDataset(val_samples, cfg, augment=False)
        
        train_loader = DataLoader(
            train_ds, batch_size=bs, shuffle=True,
            num_workers=cfg.num_workers, pin_memory=cfg.pin_memory,
            drop_last=True, persistent_workers=cfg.num_workers > 0
        )
        val_loader = DataLoader(
            val_ds, batch_size=bs, shuffle=False,
            num_workers=cfg.num_workers, pin_memory=cfg.pin_memory,
            persistent_workers=cfg.num_workers > 0
        )
        
        model = get_expert(expert_name, cfg).to(device)
        total_params = sum(p.numel() for p in model.parameters())
        trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
        print(f"Parameters: {trainable:,} / {total_params:,}")
        print_memory_stats("After model: ")
        
        # Class weights for imbalanced data
        labels = [s[1] for s in train_samples]
        class_weights = get_class_weights(labels, cfg.num_classes).to(device)
        
        criterion = nn.CrossEntropyLoss(
            weight=class_weights,
            label_smoothing=cfg.label_smoothing
        )
        
        optimizer = AdamW(model.parameters(), lr=cfg.learning_rate, weight_decay=cfg.weight_decay)
        
        steps_per_epoch = math.ceil(len(train_loader) / cfg.accumulation_steps)
        total_steps = steps_per_epoch * cfg.epochs
        
        scheduler = OneCycleLR(
            optimizer, max_lr=cfg.learning_rate,
            total_steps=total_steps + 100,
            pct_start=cfg.warmup_pct,
            anneal_strategy='cos',
            div_factor=25,
            final_div_factor=1000
        )
        
        scaler = GradScaler(enabled=amp_enabled)
        early_stopping = EarlyStopping(patience=cfg.early_stopping_patience)
        
        best_val_acc = 0.0
        best_top5 = 0.0
        start_time = time.time()
        
        for epoch in range(1, cfg.epochs + 1):
            epoch_start = time.time()
            
            train_metrics = train_one_epoch(
                model, train_loader, criterion, optimizer,
                scheduler, scaler, cfg, device, epoch
            )
            
            torch.cuda.empty_cache()
            
            val_metrics = validate(model, val_loader, criterion, cfg, device)
            
            epoch_time = time.time() - epoch_start
            lr = optimizer.param_groups[0]['lr']
            
            print(
                f"Epoch {epoch:2d}/{cfg.epochs} | "
                f"Loss: {train_metrics['train_loss']:.4f} | "
                f"Train: {train_metrics['train_acc']*100:.1f}% | "
                f"Val: {val_metrics['val_acc']*100:.1f}% | "
                f"Top5: {val_metrics['val_top5']*100:.1f}% | "
                f"F1: {val_metrics['val_f1']:.3f} | "
                f"LR: {lr:.1e} | "
                f"Time: {format_time(epoch_time)}"
            )
            
            if val_metrics["val_acc"] > best_val_acc:
                best_val_acc = val_metrics["val_acc"]
                best_top5 = val_metrics["val_top5"]
            
            if early_stopping(val_metrics["val_acc"], model, epoch):
                print(f"Early stopping at epoch {epoch}")
                break
            
            if epoch % 10 == 0:
                gc.collect()
                torch.cuda.empty_cache()
        
        early_stopping.load_best(model)
        best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
        
        total_time = time.time() - start_time
        print(f"Training completed in {format_time(total_time)}")
        print(f"Best Val Acc: {best_val_acc*100:.2f}% | Top5: {best_top5*100:.2f}% (Epoch {early_stopping.best_epoch})")
        
        result = {
            "expert_name": expert_name,
            "fold": fold,
            "best_val_acc": best_val_acc,
            "best_top5": best_top5,
            "best_epoch": early_stopping.best_epoch,
            "state_dict": best_state,
            "training_time": total_time
        }
        
        ckpt_path = cfg.checkpoint_dir / f"{expert_name}_fold{fold}_acc{best_val_acc*100:.1f}.pt"
        torch.save(result, ckpt_path)
        print(f"Saved: {ckpt_path}")
        
        return result
        
    except Exception as e:
        print(f"Error: {e}")
        traceback.print_exc()
        raise
        
    finally:
        print("\nCleaning up...")
        print_memory_stats("Before cleanup: ")
        if train_loader: del train_loader
        if val_loader: del val_loader
        if train_ds: del train_ds
        if val_ds: del val_ds
        delete_model_safely(model, optimizer, scheduler, scaler)
        clear_memory(verbose=True)

