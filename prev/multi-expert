class RadarDataset(Dataset):
    def __init__(self, samples, cfg, augment=False, is_test=False):
        self.samples = samples
        self.cfg = cfg
        self.augment = augment
        self.is_test = is_test
        self.aug = RadarAugmentation(cfg) if augment else None
    
    def __len__(self):
        return len(self.samples)
    
    def _load_channel(self, sample_dir, ch):
        files = sorted(sample_dir.glob(f"*_{ch}.npy"))
        if files:
            return np.load(files[0]).astype(np.float32)
        return np.zeros((64, self.cfg.range_bins), dtype=np.float32)
    
    def _resize(self, x):
        T, R = x.shape
        if T == self.cfg.target_frames and R == self.cfg.range_bins:
            return x
        t = torch.from_numpy(x).float().unsqueeze(0).unsqueeze(0)
        t = F.interpolate(t, size=(self.cfg.target_frames, self.cfg.range_bins), 
                         mode="bilinear", align_corners=False)
        return t.squeeze().numpy()
    
    def _normalize(self, x):
        mean, std = x.mean(), x.std()
        return (x - mean) / (std + 1e-8)
    
    def __getitem__(self, idx):
        sample_dir, label, sample_id, group_id = self.samples[idx]
        channels = []
        for ch in self.cfg.channels:
            data = self._load_channel(sample_dir, ch)
            data = self._resize(data)
            if self.augment and self.aug:
                data = self.aug(data)
            data = self._normalize(data)
            channels.append(data)
        
        x = torch.tensor(np.stack(channels), dtype=torch.float32)
        y = torch.tensor(-1 if self.is_test else label, dtype=torch.long)
        return {"rtm": x, "label": y, "sample_id": sample_id, "group_id": group_id}

