# ENHANCED DATA AUGMENTATION
# ============================================================
class RadarAugmentation:
    def __init__(self, cfg):
        self.cfg = cfg
        self.p = cfg.aug_prob
    
    def _apply(self, p=None):
        return random.random() < (p if p else self.p)
    
    def time_mask(self, x):
        if not self._apply():
            return x
        x = x.copy()
        T = x.shape[0]
        for _ in range(random.randint(1, 2)):
            mask_len = random.randint(1, min(self.cfg.time_mask_max, T // 4))
            start = random.randint(0, max(0, T - mask_len))
            x[start:start + mask_len, :] = 0
        return x
    
    def freq_mask(self, x):
        if not self._apply():
            return x
        x = x.copy()
        R = x.shape[1]
        for _ in range(random.randint(1, 2)):
            mask_len = random.randint(1, min(self.cfg.freq_mask_max, R // 4))
            start = random.randint(0, max(0, R - mask_len))
            x[:, start:start + mask_len] = 0
        return x
    
    def add_noise(self, x):
        if not self._apply(0.4):
            return x
        noise_level = random.uniform(0.02, 0.08)
        noise = np.random.randn(*x.shape).astype(np.float32) * noise_level
        return x + noise
    
    def time_warp(self, x):
        if not self._apply(0.3):
            return x
        T, R = x.shape
        scale = random.uniform(0.85, 1.15)
        new_T = max(8, int(T * scale))
        t = torch.from_numpy(x).float().unsqueeze(0).unsqueeze(0)
        t = F.interpolate(t, size=(new_T, R), mode="bilinear", align_corners=False)
        t = F.interpolate(t, size=(T, R), mode="bilinear", align_corners=False)
        return t.squeeze().numpy()
    
    def horizontal_flip(self, x):
        if not self._apply(0.3):
            return x
        return np.flip(x, axis=1).copy()
    
    def vertical_shift(self, x):
        if not self._apply(0.3):
            return x
        shift = random.randint(-10, 10)
        return np.roll(x, shift, axis=1)
    
    def __call__(self, x):
        x = self.time_warp(x)
        x = self.time_mask(x)
        x = self.freq_mask(x)
        x = self.add_noise(x)
        x = self.horizontal_flip(x)
        x = self.vertical_shift(x)
        return x

